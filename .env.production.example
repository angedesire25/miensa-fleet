# ════════════════════════════════════════════════════════════════════════════
# MiensaFleet — .env PRODUCTION (Geomatos / OVH)
# Copier ce fichier en .env sur le serveur et remplir les valeurs manquantes.
# NE PAS versionner ce fichier avec les valeurs réelles.
# ════════════════════════════════════════════════════════════════════════════

APP_NAME=MiensaFleet
APP_ENV=production
APP_KEY=                          # ← php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://app.geomatos.com

APP_LOCALE=fr
APP_TIMEZONE=Africa/Abidjan
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logs ─────────────────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de données tenant (miensafleet_geomatos) ────────────────────────────
# Hôte OVH : trouvable dans Manager OVH → Bases de données → Informations générales
# Format habituel : xxxxx.mysql.db  ou  mysql.cluster0XX.hosting.ovh.net
DB_CONNECTION=mysql
DB_HOST=                          # ← ex: xxxxx.mysql.db (OVH)
DB_PORT=3306
DB_DATABASE=miensafleet_geomatos
DB_USERNAME=                      # ← utilisateur OVH de miensafleet_geomatos
DB_PASSWORD=                      # ← mot de passe OVH

# ── Base de données landlord (miensafleet_landlord) ──────────────────────────
# Si le landlord est sur le MÊME serveur MySQL OVH, LANDLORD_DB_HOST peut
# hériter de DB_HOST (laisser commenté). Sinon définir explicitement.
# LANDLORD_DB_HOST=
LANDLORD_DB_DATABASE=miensafleet_landlord
LANDLORD_DB_USERNAME=             # ← utilisateur OVH de miensafleet_landlord
LANDLORD_DB_PASSWORD=             # ← mot de passe OVH

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
# app.geomatos.com  → panel fleet Geomatos (résolu par DomainTenantFinder)
# admin.app.geomatos.com → panel admin MiensaFleet
LANDLORD_DOMAIN=app.geomatos.com

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.geomatos.com      # ← .geomatos.com pour partager le cookie
SESSION_SECURE_COOKIE=true

# ── Cache & Queue ─────────────────────────────────────────────────────────────
# Sur OVH shared hosting → garder 'database'
# Sur VPS avec Redis → passer à 'redis'
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail SMTP OVH ─────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=ssl0.ovh.net
MAIL_PORT=465
MAIL_USERNAME=flotte@geomatos.ci  # ← adresse email OVH
MAIL_PASSWORD=                    # ← mot de passe email OVH
MAIL_FROM_ADDRESS=flotte@geomatos.ci
MAIL_FROM_NAME="MiensaFleet"

# ── Stockage fichiers ─────────────────────────────────────────────────────────
# Sur OVH : le disque 'public' stocke dans storage/app/public/
# Lancer UNE FOIS après déploiement : php artisan storage:link
FILESYSTEM_DISK=local

# ── Vite (désactivé en prod, assets pré-compilés) ────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ── Redis (optionnel — VPS uniquement) ───────────────────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
